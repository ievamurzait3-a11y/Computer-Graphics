import numpy as np
import cv2

original = cv2.imread(r'C:\Users\ievas\Downloads\original.png')
cv2.imshow('original', original)

bw = cv2.cvtColor(original, cv2.COLOR_BGR2GRAY)

(thresh,bina) = cv2.threshold(bw,127,255,cv2.THRESH_BINARY)
cv2.imshow('binary', bina)

k = np.ones((7,7), np.uint8)
eroded = cv2.erode(bina,k)
cv2.imshow('eroded', eroded)

dilated = cv2.dilate(bina,k)
cv2.imshow('dilated', dilated)

cv2.waitKey(0)