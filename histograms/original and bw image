def grayHistogram():
    root = os.getcwd()
    imgpath = os.path.join(root, r'C:\Users\ievas\Downloads\imagebw.jpg')
    img = cv.imread(imgpath, cv.IMREAD_GRAYSCALE)

    hist = cv.calcHist([img], [0], None, [256], [0, 256])

    plt.figure()
    plt.plot(hist)
    plt.xlabel('bins')
    plt.ylabel('number of pixels')
    plt.title('histogram_original')

    save_path = r'C:\Users\ievas\Downloads\imagebwh.jpg'
    plt.savefig(save_path)

    plt.show()

grayHistogram()