from skimage import io, exposure
import matplotlib.pyplot as plt
import os
import cv2 as cv
import numpy as np

path = r'C:\Users\ievas\Downloads\imagebw.jpg'
img = io.imread(path, as_gray=True)

img_ahe = ((exposure.equalize_adapthist(img, kernel_size=None, clip_limit=1.0)) * 255).astype(np.uint8)

cv.imshow('AHE', img_ahe)
cv.imwrite(r'C:\Users\ievas\Downloads\imagebw2.jpg', img_ahe)




def grayHistogram():
    root = os.getcwd()
    imgpath = os.path.join(root, r'C:\Users\ievas\Downloads\imagebw2.jpg')
    img = cv.imread(imgpath, cv.IMREAD_GRAYSCALE)

    hist = cv.calcHist([img], [0], None, [256], [0, 256])

    plt.figure()
    plt.plot(hist)
    plt.xlabel('bins')
    plt.ylabel('number of pixels')
    plt.title('histogram_ahe')

    save_path = r'C:\Users\ievas\Downloads\imagebw2h.jpg'
    plt.savefig(save_path)

    plt.show()

grayHistogram()